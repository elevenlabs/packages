{
  "name": "@elevenlabs/react-native",
  "version": "0.5.11",
  "description": "ElevenLabs React Native SDK for the Agents Platform",
  "main": "./dist/lib.js",
  "module": "./dist/lib.module.js",
  "source": "src/index.ts",
  "unpkg": "./dist/lib.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lib.modern.js",
      "require": "./dist/lib.js"
    }
  },
  "scripts": {
    "bundle": "microbundle --jsx React.createElement --jsxFragment React.Fragment --jsxImportSource react src/index.ts",
    "build": "BROWSERSLIST_ENV=modern node --run bundle",
    "dev": "BROWSERSLIST_ENV=modern node --run bundle -- --watch --no-compress",
    "clean": "rm -rf ./dist",
    "check-types": "tsc --noEmit --skipLibCheck",
    "lint:es": "pnpm exec eslint .",
    "lint:prettier": "prettier 'src/**/*.ts' --check"
  },
  "keywords": [
    "elevenlabs",
    "react-native",
    "conversational-ai",
    "webrtc",
    "voice",
    "ai"
  ],
  "author": "ElevenLabs",
  "license": "MIT",
  "peerDependencies": {
    "@livekit/react-native": "^2.9.2",
    "@livekit/react-native-webrtc": "^137.0.2",
    "react": ">=17.0.0",
    "react-native": ">=0.70.0"
  },
  "dependencies": {
    "@elevenlabs/react": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.1",
    "eslint": "^9.8.0",
    "microbundle": "^0.15.1",
    "typescript": "^5.5.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elevenlabs/packages.git",
    "directory": "packages/react-native"
  },
  "publishConfig": {
    "access": "public"
  }
}
