{
  "name": "@elevenlabs/client",
  "version": "1.7.0",
  "description": "ElevenLabs JavaScript Client Library",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "unpkg": "./dist/lib.iife.js",
      "default": "./dist/index.js"
    },
    "./internal": "./dist/internal.js"
  },
  "scripts": {
    "generate-version": "node ../../scripts/generate-version.mjs",
    "generate-worklets": "node scripts/generateWorklets.js && prettier src/utils/*.generated.ts --write",
    "build:esm": "tsc --build tsconfig.build.json",
    "build:iife": "rolldown src/index.ts -f iife --name ElevenLabsClient -o dist/lib.iife.js --sourcemap --external react --external react-dom",
    "build": "node --run generate-version && node --run build:esm && node --run build:iife",
    "dev": "tsc --build --watch",
    "clean": "tsc --build --clean && rm -rf ./dist",
    "lint:es": "pnpm exec eslint .",
    "lint:prettier": "prettier \"src/**/*.ts\" --check",
    "test": "vitest"
  },
  "keywords": [],
  "author": "ElevenLabs",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node-wav": "^0.0.4",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "mock-socket": "^9.3.1",
    "node-wav": "^0.0.2",
    "playwright": "^1.59.1",
    "rolldown": "^1.0.0-rc.9",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elevenlabs/packages.git",
    "directory": "packages/client"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "dependencies": {
    "@elevenlabs/types": "workspace:*",
    "livekit-client": "^2.11.4"
  }
}
