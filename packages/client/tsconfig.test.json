{
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "noEmit": true,
    "rootDir": "./src",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src/**/*.test.ts", "src/**/__tests__/**/*.ts"],
  "references": [
    {
      "path": "./tsconfig.common.json"
    },
    {
      "path": "./tsconfig.web.json"
    }
  ]
}
