    "@types/hast": "^3.0.4",
    "@types/preact-custom-element": "^4.0.4",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "eslint": "^10.3.0",
    "msw": "^2.7.5",
