{
  "name": "elevenlabs-react-native-example",
  "version": "1.1.19",
  "main": "index.js",
  "private": true,
  "scripts": {
    "dev": "expo start",
    "android": "echo '🚨🚨 Once Expo has started, press `a` 🚨🚨' && node --run dev",
    "ios": "echo '🚨🚨 Once Expo has started, press `i` 🚨🚨' && node --run dev",
    "web": "expo start --web",
    "build:android": "expo prebuild --platform android",
    "build:ios": "expo prebuild --platform ios",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^15.0.1",
    "@elevenlabs/react-native": "workspace:*",
    "@livekit/react-native": "^2.9.6",
    "@livekit/react-native-expo-plugin": "^1.0.1",
    "@livekit/react-native-webrtc": "^137.0.2",
    "expo": "~55.0.23",
    "expo-dev-client": "~57.0.5",
    "expo-image-picker": "~57.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-web": "~0.21.2",
    "@expo/metro-runtime": "~57.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/node": "^20.8.0",
    "@types/react": "~19.2.17",
    "typescript": "^5.5.4"
  }
}
