{
  "expo": {
    "scheme": "skia",
    "orientation": "landscape",
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "name": "ElevenLabs Fact Checker",
    "slug": "fact-checker",
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anonymous.factchecker"
    }
  }
}
