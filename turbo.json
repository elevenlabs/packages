{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": [
        "generate-version",
        "generate-worklets",
        "generate-types",
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "src/**",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsconfig.test.json"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "generated/**",
        "*.tsbuildinfo"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "**/*.test.*",
        "**/*.spec.*",
        "vitest.config.ts",
        "jest.config.*",
        "tsconfig.build.json",
        "tsconfig.test.json"
      ],
      "passThroughEnv": ["PLAYWRIGHT_*", "HOME", "CI"]
    },
    "lint": {
      "dependsOn": ["^build", "lint:es", "lint:prettier", "check-types"]
    },
    "lint:es": {
      "dependsOn": ["generate-version", "generate-worklets", "generate-types"],
      "inputs": ["src/**", ".eslintrc*", "eslint.config.*"]
    },
    "lint:prettier": {
      "dependsOn": ["generate-version", "generate-worklets", "generate-types"],
      "inputs": ["src/**", ".prettierrc*", "prettier.config.*"]
    },
    "check-types": {
      "dependsOn": [
        "^build",
        "generate-version",
        "generate-worklets",
        "generate-types"
      ],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsconfig.test.json"
      ]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "generate-version",
        "generate-worklets",
        "generate-types",
        "^build"
      ]
    },
    "generate": {
      "dependsOn": [
        "generate-types",
        "generate-version",
        "generate-worklets"
      ]
    },
    "generate-types": {
      "inputs": ["schemas/**/*.yaml", "schemas/**/*.yml"],
      "outputs": ["generated/**"]
    },
    "generate-version": {
      "inputs": ["package.json"],
      "outputs": ["src/version.ts"]
    },
    "generate-worklets": {
      "inputs": ["scripts/generateWorklets.js", "worklets/**/*.js"],
      "outputs": ["src/utils/*.generated.ts"]
    }
  }
}
