{
  "name": "packages",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "create": "node scripts/create",
    "lint": "turbo lint",
    "test": "turbo test",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "ci": "turbo check-types lint test build",
    "generate:types": "turbo run generate --filter=@elevenlabs/types",
    "prepare": "husky install",
    "dev": "turbo dev",
    "clean": "turbo clean",
    "changeset": "changeset",
    "publish": "turbo build lint && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "args": "^5.0.3",
    "fs-extra": "^11.2.0",
    "husky": "^9.1.3",
    "npm": "^11.6.4",
    "prettier": "^3.3.3",
    "turbo": "2.5.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ],
    "overrides": {
      "@asyncapi/parser": "^3.6.0",
      "rollup@^4": ">=4.59.0",
      "picomatch@~3": ">=3.0.2",
      "picomatch@^4": ">=4.0.4",
      "flatted": ">=3.4.2",
      "h3": ">=2.0.1-rc.15",
      "undici@^6": ">=6.24.0",
      "undici@^7": ">=7.24.0",
      "tar": ">=7.5.11",
      "svgo@^2": ">=2.8.1",
      "serialize-javascript": ">=7.0.3",
      "minimatch@^3": ">=3.1.4",
      "minimatch@^9": ">=9.0.7",
      "minimatch@^10": ">=10.2.3",
      "@isaacs/brace-expansion@^5": ">=5.0.1"
    },
    "patchedDependencies": {
      "livekit-client@2.16.0": "patches/livekit-client@2.16.0.patch"
    }
  },
  "packageManager": "pnpm@10.28.1"
}
